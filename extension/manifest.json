{
  "manifest_version": 3,
  "name": "SocialSpy",
  "version": "1.0",
  "description": "Right-click any username to search across 400+ social networks!",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SocialSpy"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}